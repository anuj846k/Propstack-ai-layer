# Google Gemini (AI Agent)
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio
GEMINI_LIVE_LOCATION=us-central1

# Supabase (Database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Demo
DEMO_LANDLORD_ID=your_landlord_uuid_here

# App Config
ENVIRONMENT=development
LOG_LEVEL=INFO
NEXTJS_BASE_URL=http://localhost:3000
INTERNAL_API_SECRET=propstack-internal-secret

# Rent Settings
RENT_DUE_DAY=1
GRACE_PERIOD_DAYS=5

# Payment Webhooks
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Twilio Voice (Tenant Calls)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VOICE_FROM_NUMBER=+1234567890
TWILIO_TRIAL_MODE=true
TWILIO_TRIAL_ALLOWED_TO_NUMBERS=+9876543210
TWILIO_STREAM_SAMPLE_RATE_HZ=8000
TWILIO_VALIDATE_WEBHOOK_SIGNATURE=true
PUBLIC_BASE_URL=http://localhost:8001

# Live Sessions (Twilio Media Stream)
LIVE_INPUT_SAMPLE_RATE_HZ=16000
LIVE_OUTPUT_SAMPLE_RATE_HZ=24000
ENABLE_CUSTOM_BRIDGE_FALLBACK=false

# Call Policy (Time window in IST)
CALL_WINDOW_START_HOUR=9
CALL_WINDOW_END_HOUR=20
MAX_CALL_ATTEMPTS_PER_TENANT_PER_DAY=2

# Reserved for future (not currently used)
# SARVAM_API_KEY=
# LIVEKIT_URL=
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# SIP_TRUNK_ID=
